diff -ruN a/mm/rustlux_softecc.c b/mm/rustlux_softecc.c
--- a/mm/rustlux_softecc.c
+++ b/mm/rustlux_softecc.c
@@ -0,0 +1,284 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * rustlux_softecc.c — software SECDED scrubber
+ * Copyright (C) 2026 Yadiel Abner Rodriguez Jorge (neokuze) <imneokuze@gmail.com>
+ *
+ * See include/linux/rustlux_softecc.h for the theory of operation.
+ */
+#include <linux/kernel.h>
+#include <linux/list.h>
+#include <linux/slab.h>
+#include <linux/workqueue.h>
+#include <linux/jiffies.h>
+#include <linux/sysctl.h>
+#include <linux/panic.h>
+#include <linux/mutex.h>
+#include <linux/set_memory.h>
+#include <linux/mm.h>
+#include <linux/io.h>
+#include <linux/rustlux_softecc.h>
+
+#include <asm/sections.h>
+
+static int sysctl_softecc_enabled = 1;
+static unsigned int sysctl_softecc_interval_ms = 2000;
+
+static LIST_HEAD(softecc_regions);
+static DEFINE_MUTEX(softecc_lock);
+static atomic64_t softecc_corrected = ATOMIC64_INIT(0);
+static atomic64_t softecc_uncorrectable = ATOMIC64_INIT(0);
+
+struct softecc_region {
+	struct list_head list;
+	const char *name;
+	u64 *addr;
+	size_t words;
+	u8 *codes;
+	bool readonly;
+};
+
+struct rustlux_secc_result {
+	s32 status;	/* RUSTLUX_SECC_* */
+	u64 data;	/* corrected word when status == CORRECTED */
+};
+
+#ifdef CONFIG_RUST
+
+/* Rust implementation in rust/kernel/rustlux.rs */
+extern u8 rustlux_softecc_encode(u64 data);
+extern struct rustlux_secc_result rustlux_softecc_verify(u64 data, u8 code);
+
+#else /* !CONFIG_RUST */
+
+/*
+ * C fallback — Hamming(72,64) SECDED, same construction as the Rust
+ * core: 71 codeword positions (1..71), parity bits at the powers of
+ * two, data bits filling the rest in order, plus one overall parity
+ * bit (bit 7 of the code byte) to tell single from double errors.
+ */
+#define SECC_POSITIONS	71
+
+static inline bool secc_is_parity_pos(u32 pos)
+{
+	return (pos & (pos - 1)) == 0;
+}
+
+static u32 secc_data_syndrome(u64 data)
+{
+	u32 syn = 0, bit = 0, pos;
+
+	for (pos = 1; pos <= SECC_POSITIONS; pos++) {
+		if (secc_is_parity_pos(pos))
+			continue;
+		if ((data >> bit) & 1)
+			syn ^= pos;
+		bit++;
+	}
+	return syn;
+}
+
+static u8 rustlux_softecc_encode(u64 data)
+{
+	u8 code = secc_data_syndrome(data) & 0x7f;
+
+	if ((hweight64(data) + hweight8(code)) & 1)
+		code |= 0x80;
+	return code;
+}
+
+static struct rustlux_secc_result rustlux_softecc_verify(u64 data, u8 code)
+{
+	struct rustlux_secc_result r = {
+		.status = RUSTLUX_SECC_CLEAN,
+		.data = data,
+	};
+	u32 syn = secc_data_syndrome(data) ^ (code & 0x7f);
+	bool parity_ok = !((hweight64(data) + hweight8(code)) & 1);
+	u32 pos, bit = 0;
+
+	if (!syn && parity_ok)
+		return r;
+
+	if (!syn && !parity_ok) {
+		/* the overall parity bit itself flipped; data intact */
+		r.status = RUSTLUX_SECC_CORRECTED;
+		return r;
+	}
+
+	if (syn && parity_ok) {
+		/* even number of flips: beyond SECDED */
+		r.status = RUSTLUX_SECC_UNCORRECTABLE;
+		return r;
+	}
+
+	/* single-bit error at codeword position syn */
+	if (syn > SECC_POSITIONS) {
+		r.status = RUSTLUX_SECC_UNCORRECTABLE;
+		return r;
+	}
+	if (secc_is_parity_pos(syn)) {
+		/* a shadow parity bit flipped; data intact */
+		r.status = RUSTLUX_SECC_CORRECTED;
+		return r;
+	}
+	for (pos = 1; pos < syn; pos++)
+		if (!secc_is_parity_pos(pos))
+			bit++;
+	r.data = data ^ BIT_ULL(bit);
+	r.status = RUSTLUX_SECC_CORRECTED;
+	return r;
+}
+
+#endif /* CONFIG_RUST */
+
+static void softecc_fix_word(struct softecc_region *r, size_t i, u64 good)
+{
+	unsigned long page = (unsigned long)&r->addr[i] & PAGE_MASK;
+
+	if (r->readonly)
+		set_memory_rw(page, 1);
+	WRITE_ONCE(r->addr[i], good);
+	if (r->readonly)
+		set_memory_ro(page, 1);
+}
+
+static void softecc_scrub_region(struct softecc_region *r)
+{
+	size_t i;
+
+	for (i = 0; i < r->words; i++) {
+		u64 word = READ_ONCE(r->addr[i]);
+		struct rustlux_secc_result res =
+			rustlux_softecc_verify(word, r->codes[i]);
+		phys_addr_t phys;
+
+		switch (res.status) {
+		case RUSTLUX_SECC_CORRECTED:
+			softecc_fix_word(r, i, res.data);
+			r->codes[i] = rustlux_softecc_encode(res.data);
+			atomic64_inc(&softecc_corrected);
+			phys = virt_to_phys(&r->addr[i]);
+			pr_warn("rustlux_softecc: corrected single-bit flip in %s at %px (phys %pa) — DRAM produced a real error, check EXPO/XMP stability\n",
+				r->name, &r->addr[i], &phys);
+			break;
+
+		case RUSTLUX_SECC_UNCORRECTABLE:
+			atomic64_inc(&softecc_uncorrectable);
+			pr_alert("rustlux_softecc: UNCORRECTABLE multi-bit corruption in %s at %px — kernel state is not trustworthy\n",
+				 r->name, &r->addr[i]);
+			add_taint(TAINT_MACHINE_CHECK, LOCKDEP_STILL_OK);
+			/* reseal so we report each event once */
+			r->codes[i] = rustlux_softecc_encode(word);
+			break;
+
+		default:
+			break;
+		}
+	}
+}
+
+static void softecc_scrub_fn(struct work_struct *work);
+static DECLARE_DELAYED_WORK(softecc_work, softecc_scrub_fn);
+
+static void softecc_scrub_fn(struct work_struct *work)
+{
+	struct softecc_region *r;
+
+	if (READ_ONCE(sysctl_softecc_enabled)) {
+		mutex_lock(&softecc_lock);
+		list_for_each_entry(r, &softecc_regions, list)
+			softecc_scrub_region(r);
+		mutex_unlock(&softecc_lock);
+	}
+
+	schedule_delayed_work(&softecc_work,
+		msecs_to_jiffies(READ_ONCE(sysctl_softecc_interval_ms)));
+}
+
+int rustlux_softecc_protect(const char *name, void *addr, size_t size,
+			    bool readonly)
+{
+	struct softecc_region *r;
+	size_t i;
+
+	r = kzalloc(sizeof(*r), GFP_KERNEL);
+	if (!r)
+		return -ENOMEM;
+
+	r->name = name;
+	r->addr = addr;
+	r->words = size / sizeof(u64);
+	r->readonly = readonly;
+	r->codes = kvmalloc(r->words, GFP_KERNEL);
+	if (!r->codes) {
+		kfree(r);
+		return -ENOMEM;
+	}
+
+	for (i = 0; i < r->words; i++)
+		r->codes[i] = rustlux_softecc_encode(READ_ONCE(r->addr[i]));
+
+	mutex_lock(&softecc_lock);
+	list_add_tail(&r->list, &softecc_regions);
+	mutex_unlock(&softecc_lock);
+
+	pr_info("rustlux_softecc: protecting %s (%zu KiB, %zu words)\n",
+		name, size >> 10, r->words);
+	return 0;
+}
+
+void rustlux_softecc_reseal(void *addr)
+{
+	struct softecc_region *r;
+	size_t i;
+
+	mutex_lock(&softecc_lock);
+	list_for_each_entry(r, &softecc_regions, list) {
+		if (r->addr != addr)
+			continue;
+		for (i = 0; i < r->words; i++)
+			r->codes[i] =
+				rustlux_softecc_encode(READ_ONCE(r->addr[i]));
+		break;
+	}
+	mutex_unlock(&softecc_lock);
+}
+
+static const struct ctl_table rustlux_softecc_sysctls[] = {
+	{
+		.procname	= "rustlux_softecc",
+		.data		= &sysctl_softecc_enabled,
+		.maxlen		= sizeof(int),
+		.mode		= 0644,
+		.proc_handler	= proc_dointvec_minmax,
+		.extra1		= SYSCTL_ZERO,
+		.extra2		= SYSCTL_ONE,
+	},
+	{
+		.procname	= "rustlux_softecc_interval_ms",
+		.data		= &sysctl_softecc_interval_ms,
+		.maxlen		= sizeof(unsigned int),
+		.mode		= 0644,
+		.proc_handler	= proc_douintvec_minmax,
+		.extra1		= SYSCTL_ONE_HUNDRED,
+	},
+};
+
+static int __init rustlux_softecc_init(void)
+{
+	/*
+	 * Stable-after-init structures only, so no reseal coordination
+	 * is needed. The IDT registers itself from
+	 * arch/x86/kernel/idt.c; page tables and creds need write-path
+	 * hooks — future work (see header).
+	 */
+	rustlux_softecc_protect("ro_after_init", __start_ro_after_init,
+				__end_ro_after_init - __start_ro_after_init,
+				true);
+
+	register_sysctl_init("vm", rustlux_softecc_sysctls);
+	schedule_delayed_work(&softecc_work,
+		msecs_to_jiffies(sysctl_softecc_interval_ms));
+	return 0;
+}
+late_initcall(rustlux_softecc_init);
