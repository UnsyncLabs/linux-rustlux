diff -ruN a/arch/x86/kernel/idt.c b/arch/x86/kernel/idt.c
--- a/arch/x86/kernel/idt.c
+++ b/arch/x86/kernel/idt.c
@@ -3,6 +3,7 @@
  * Interrupt descriptor table related code
  */
 #include <linux/interrupt.h>
+#include <linux/rustlux_softecc.h>
 
 #include <asm/cpu_entry_area.h>
 #include <asm/set_memory.h>
@@ -314,6 +315,14 @@
 	/* Make the IDT table read only */
 	set_memory_ro((unsigned long)&idt_table, 1);
 
+	/*
+	 * The IDT layout is final and read-only from here on: register
+	 * it with the Rustlux soft-ECC scrubber so a DRAM bit flip in a
+	 * gate descriptor (or a rowhammer-induced one) is corrected
+	 * instead of redirecting an exception into garbage.
+	 */
+	rustlux_softecc_protect("idt", idt_table, sizeof(idt_table), true);
+
 	idt_setup_done = true;
 }
 
diff -ruN a/include/linux/rustlux_softecc.h b/include/linux/rustlux_softecc.h
--- a/include/linux/rustlux_softecc.h
+++ b/include/linux/rustlux_softecc.h
@@ -0,0 +1,97 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * rustlux_softecc.h — software SECDED for critical kernel structures
+ * Copyright (C) 2026 Yadiel Abner Rodriguez Jorge (neokuze) <imneokuze@gmail.com>
+ *
+ * THEORY OF OPERATION
+ *
+ * Consumer hardware has no host-visible ECC: a DRAM bit flip in a
+ * kernel structure is silent until it becomes a crash (or a rowhammer
+ * privilege escalation). True per-access ECC is impossible in
+ * software — we cannot intercept every load — but *periodic
+ * scrub-and-correct* of a small, high-value set of structures is
+ * practical and is how space-grade systems have protected RAM from
+ * radiation-induced flips for decades.
+ *
+ * Each protected region keeps a shadow array of 8-bit SECDED codes,
+ * one per 64-bit word (Hamming(72,64): 12.5% memory overhead on the
+ * protected region only). A scrubber runs every
+ * vm.rustlux_softecc_interval_ms and for every word:
+ *
+ *   - clean                → nothing
+ *   - single-bit flip      → CORRECTED in place, pr_warn with the
+ *                            physical address (feeds the mem sentinel
+ *                            picture of DRAM health)
+ *   - double-bit flip      → uncorrectable: pr_alert + taint. The
+ *                            admin knows the machine is lying to it.
+ *
+ * Protected at boot (stable after init, so no write coordination):
+ *   - the __ro_after_init section (registered from this file's init)
+ *   - the IDT (registered from arch/x86/kernel/idt.c once its layout
+ *     is final and it has been set read-only)
+ *
+ * Mutable structures (page tables, creds) need write-path hooks to
+ * reseal on legitimate modification — future work. The reseal API
+ * below is the entry point for that.
+ *
+ * The encode/verify core lives in rust/kernel/rustlux.rs when
+ * CONFIG_RUST=y (mirrored by the standalone crate
+ * rust/rustlux_mm/src/soft_ecc.rs), with an equivalent C fallback.
+ *
+ * LIMITS (honest ones):
+ *   - There is a window between the flip and the next scrub pass in
+ *     which the corrupted value can be consumed. This shrinks MTTR,
+ *     it is not per-access ECC.
+ *   - Only whole 64-bit words are protected; a region's trailing
+ *     sub-word bytes are left uncovered.
+ *   - Corrections to read-only mappings toggle page permissions
+ *     (set_memory_rw/ro), which briefly widens the write window on
+ *     that page.
+ */
+#ifndef _LINUX_RUSTLUX_SOFTECC_H
+#define _LINUX_RUSTLUX_SOFTECC_H
+
+#include <linux/types.h>
+
+/* result of verifying one word */
+#define RUSTLUX_SECC_CLEAN		0
+#define RUSTLUX_SECC_CORRECTED		1
+#define RUSTLUX_SECC_UNCORRECTABLE	-1
+
+#ifdef CONFIG_RUSTLUX_SOFTECC
+
+/**
+ * rustlux_softecc_protect - start scrubbing a memory region
+ * @name:     label used in log messages
+ * @addr:     start of the region (8-byte aligned)
+ * @size:     region size in bytes (protected: size / 8 words)
+ * @readonly: region is mapped RO; corrections must toggle page perms
+ *
+ * Computes the shadow SECDED codes and registers the region with the
+ * scrubber. Returns 0 or -ENOMEM.
+ */
+int rustlux_softecc_protect(const char *name, void *addr, size_t size,
+			    bool readonly);
+
+/**
+ * rustlux_softecc_reseal - recompute codes after a legitimate write
+ * @addr: start address previously passed to rustlux_softecc_protect()
+ *
+ * Must be called by any code path that intentionally modifies a
+ * protected region, otherwise the scrubber will "correct" the new
+ * value back to the old one.
+ */
+void rustlux_softecc_reseal(void *addr);
+
+#else /* !CONFIG_RUSTLUX_SOFTECC */
+
+static inline int rustlux_softecc_protect(const char *name, void *addr,
+					  size_t size, bool readonly)
+{
+	return 0;
+}
+static inline void rustlux_softecc_reseal(void *addr) { }
+
+#endif /* CONFIG_RUSTLUX_SOFTECC */
+
+#endif /* _LINUX_RUSTLUX_SOFTECC_H */
diff -ruN a/mm/Kconfig b/mm/Kconfig
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -1449,6 +1449,22 @@
 
 	  Note: now only empty user PTE page table pages will be reclaimed.
 
+config RUSTLUX_SOFTECC
+	bool "Rustlux software SECDED for critical kernel structures"
+	depends on X86_64
+	default y
+	help
+	  Keeps Hamming(72,64) SECDED codes for a small set of critical
+	  kernel structures (__ro_after_init section, IDT) and scrubs
+	  them periodically, correcting single-bit DRAM flips in place
+	  and reporting uncorrectable ones. Intended for machines
+	  without host-visible ECC running marginal memory (aggressive
+	  EXPO/XMP profiles), and as a rowhammer mitigation for
+	  attacker-induced flips in kernel data.
+
+	  Memory overhead is 12.5% of the protected regions (a few
+	  KiB). If unsure, say Y.
+
 config FIND_NORMAL_PAGE
 	def_bool n
 
