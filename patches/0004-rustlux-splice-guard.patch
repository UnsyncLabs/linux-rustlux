diff -ruN a/fs/splice.c b/fs/splice.c
--- a/fs/splice.c
+++ b/fs/splice.c
@@ -36,6 +36,7 @@
 #include <linux/net.h>
 #include <linux/socket.h>
 #include <linux/sched/signal.h>
+#include <linux/rustlux_guard.h>
 
 #include "internal.h"
 
@@ -931,6 +932,17 @@
 static ssize_t do_splice_from(struct pipe_inode_info *pipe, struct file *out,
                               loff_t *ppos, size_t len, unsigned int flags)
 {
+	/*
+	 * Rustlux splice guard: verify write permission to page cache
+	 * BEFORE any page is touched. This blocks Dirty Pipe, Copy Fail,
+	 * and Dirty Frag class vulnerabilities at the entry point.
+	 */
+	if (out->f_inode) {
+		int ret = rustlux_check_splice_perm(out->f_inode);
+		if (ret < 0)
+			return ret;
+	}
+
 	if (unlikely(!out->f_op->splice_write))
 		return warn_unsupported(out, "write");
 	return out->f_op->splice_write(pipe, out, ppos, len, flags);
diff -ruN a/include/linux/rustlux_guard.h b/include/linux/rustlux_guard.h
--- a/include/linux/rustlux_guard.h
+++ b/include/linux/rustlux_guard.h
@@ -0,0 +1,71 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * rustlux_guard.h — Page cache write protection for Rustlux
+ * Copyright (C) 2026 Yadiel Abner Rodriguez Jorge (neokuze) <imneokuze@gmail.com>
+ *
+ * Blocks splice/sendfile writes to page cache for files that are:
+ * - SUID or SGID
+ * - Immutable (FS_IMMUTABLE_FL)
+ * - On a read-only filesystem
+ *
+ * When CONFIG_RUST is enabled, calls the Rust implementation in
+ * rust/kernel/rustlux.rs for memory-safe guarantees.
+ * Otherwise falls back to an equivalent C inline implementation.
+ */
+#ifndef _LINUX_RUSTLUX_GUARD_H
+#define _LINUX_RUSTLUX_GUARD_H
+
+#include <linux/fs.h>
+#include <linux/errno.h>
+
+#ifdef CONFIG_RUST
+
+/* Rust implementation in rust/kernel/rustlux.rs */
+extern int rustlux_check_splice_write(u32 i_mode, u32 i_flags, u8 sb_readonly);
+
+/**
+ * rustlux_check_splice_perm - Check if splice write to page cache is safe
+ * @inode: target inode
+ *
+ * Calls into Rust for memory-safe permission checking.
+ */
+static inline int rustlux_check_splice_perm(struct inode *inode)
+{
+	return rustlux_check_splice_write(inode->i_mode, inode->i_flags,
+					  IS_RDONLY(inode) ? 1 : 0);
+}
+
+#else /* !CONFIG_RUST */
+
+/**
+ * rustlux_check_splice_perm - Check if splice write to page cache is safe
+ * @inode: target inode
+ *
+ * C fallback — same logic, no Rust dependency.
+ *
+ * Mitigates:
+ *   CVE-2022-0847  (Dirty Pipe)
+ *   CVE-2026-31431 (Copy Fail)
+ *   CVE-2026-43284 (Dirty Frag / xfrm)
+ *   CVE-2026-43500 (Dirty Frag / rxrpc)
+ */
+static inline int rustlux_check_splice_perm(struct inode *inode)
+{
+	/* Block writes to SUID/SGID files via splice */
+	if (inode->i_mode & (S_ISUID | S_ISGID))
+		return -EPERM;
+
+	/* Block writes to immutable files */
+	if (IS_IMMUTABLE(inode))
+		return -EPERM;
+
+	/* Block writes to read-only filesystems */
+	if (IS_RDONLY(inode))
+		return -EROFS;
+
+	return 0;
+}
+
+#endif /* CONFIG_RUST */
+
+#endif /* _LINUX_RUSTLUX_GUARD_H */
