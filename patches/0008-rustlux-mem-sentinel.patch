 #include <linux/vmcore_info.h>
+#include <linux/rustlux_memsentinel.h>
 
 #include <asm/fred.h>
 #include <asm/cpu_device_id.h>
@@ -152,6 +153,14 @@
 
 void mce_log(struct mce_hw_err *err)
 {
+	/*
+	 * Rustlux memory sentinel: feed every logged machine check into
+	 * the DRAM instability detector. Errors sourced from the memory
+	 * controller (UMC on AMD, IMC on Intel) are the earliest visible
+	 * symptom of an unstable EXPO/XMP profile.
+	 */
+	rustlux_memsentinel_record(&err->m);
+
 	if (mce_gen_pool_add(err))
 		irq_work_queue(&mce_irq_work);
 }
diff -ruN a/include/linux/rustlux_memsentinel.h b/include/linux/rustlux_memsentinel.h
--- a/include/linux/rustlux_memsentinel.h
+++ b/include/linux/rustlux_memsentinel.h
@@ -0,0 +1,59 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * rustlux_memsentinel.h — DRAM instability detector for Rustlux
+ * Copyright (C) 2026 Yadiel Abner Rodriguez Jorge (neokuze) <imneokuze@gmail.com>
+ *
+ * THEORY OF OPERATION
+ *
+ * The kernel cannot make unstable DRAM stable: memory frequency and
+ * timings are programmed by firmware (AGESA / MRC) during memory
+ * training, before the kernel boots, and cannot be reprogrammed at
+ * runtime. What the kernel CAN do is:
+ *
+ *   1. Detect the symptom. An unstable EXPO/XMP profile produces
+ *      machine-check errors sourced from the memory controller
+ *      (corrected at first, uncorrected when it is about to crash).
+ *   2. Warn loudly with actionable guidance (lower MT/s, raise
+ *      VSOC/VDDQ, retrain) BEFORE silent corruption becomes a panic.
+ *   3. Contain the blast radius: queue pages with uncorrected errors
+ *      for memory_failure() handling, so a marginal DIMM degrades
+ *      service instead of taking down the whole machine.
+ *
+ * Sysctls:
+ *   vm.rustlux_memsentinel            (0/1, default 1)
+ *   vm.rustlux_memsentinel_threshold  (corrected errors per 60s
+ *                                      window before warning,
+ *                                      default 8)
+ */
+#ifndef _LINUX_RUSTLUX_MEMSENTINEL_H
+#define _LINUX_RUSTLUX_MEMSENTINEL_H
+
+#include <linux/types.h>
+
+struct mce;
+
+/* Actions decided by the (Rust or C) rate-tracking core */
+#define RUSTLUX_MS_ACTION_NONE		0
+#define RUSTLUX_MS_ACTION_WARN		1
+#define RUSTLUX_MS_ACTION_OFFLINE	2
+
+#ifdef CONFIG_X86_MCE
+
+/**
+ * rustlux_memsentinel_record - feed a machine check into the sentinel
+ * @m: the logged machine check record (&mce_hw_err.m from mce_log())
+ *
+ * Called from mce_log(). Ignores anything that is not a memory
+ * error. Safe to call from MCE context: the decision core is
+ * lock-free (atomics only) and the containment work is deferred
+ * through memory_failure_queue().
+ */
+void rustlux_memsentinel_record(struct mce *m);
+
+#else /* !CONFIG_X86_MCE */
+
+static inline void rustlux_memsentinel_record(struct mce *m) { }
+
+#endif /* CONFIG_X86_MCE */
+
+#endif /* _LINUX_RUSTLUX_MEMSENTINEL_H */
