+// ─── Soft-ECC (patch 0009) ───────────────────────────────────────────────────
+//
+// Hamming(72,64) SECDED core: 71 codeword positions (1..=71), parity
+// bits at the powers of two, the 64 data bits filling the rest in
+// order, plus one overall-parity bit (bit 7 of the code byte) to tell
+// single flips from double flips. Pure functions, no state. Mirrored
+// by rust/rustlux_mm/src/soft_ecc.rs (where the unit tests live).
+
+/// Number of positional codeword bits (64 data + 7 parity).
+const SECC_POSITIONS: u32 = 71;
+
+/// FFI result of verifying one protected word.
+///
+/// Layout matches `struct rustlux_secc_result` in mm/rustlux_softecc.c.
+#[repr(C)]
+pub struct SoftEccResult {
+    /// 0 = clean, 1 = corrected, -1 = uncorrectable.
+    pub status: i32,
+    /// Corrected data word (valid when `status` == 1).
+    pub data: u64,
+}
+
+fn secc_is_parity_pos(pos: u32) -> bool {
+    pos & (pos - 1) == 0
+}
+
+/// XOR of the codeword positions of every set data bit.
+fn secc_data_syndrome(data: u64) -> u32 {
+    let mut syn = 0u32;
+    let mut bit = 0u32;
+    for pos in 1..=SECC_POSITIONS {
+        if secc_is_parity_pos(pos) {
+            continue;
+        }
+        if (data >> bit) & 1 == 1 {
+            syn ^= pos;
+        }
+        bit += 1;
+    }
+    syn
+}
+
+/// Compute the 8-bit SECDED code for a 64-bit word.
+///
+/// Called from mm/rustlux_softecc.c when sealing a protected region.
+#[no_mangle]
+pub extern "C" fn rustlux_softecc_encode(data: u64) -> u8 {
+    // parity bit i (position 2^i) must cancel bit i of the data
+    // syndrome, so the low 7 bits of the code ARE the syndrome
+    let mut code = (secc_data_syndrome(data) & 0x7f) as u8;
+
+    // overall parity over data + positional parity bits, stored so
+    // the total number of ones (including this bit) is even
+    if (data.count_ones() + (code as u32).count_ones()) & 1 == 1 {
+        code |= 0x80;
+    }
+    code
+}
+
+/// Verify a word against its code, correcting single-bit flips.
+///
+/// Called from the scrubber in mm/rustlux_softecc.c for every word of
+/// every protected region.
+///
+/// # Returns
+/// `SoftEccResult` with:
+/// * `status` 0 - word and code are consistent
+/// * `status` 1 - exactly one bit flipped; `data` holds the corrected word
+/// * `status` -1 - two or more bits flipped: beyond SECDED, data is lost
+#[no_mangle]
+pub extern "C" fn rustlux_softecc_verify(data: u64, code: u8) -> SoftEccResult {
+    // XOR of distinct powers of two == the integer value of the low
+    // 7 code bits, so the parity contribution to the syndrome is just
+    // (code & 0x7f)
+    let syn = secc_data_syndrome(data) ^ (code & 0x7f) as u32;
+    let parity_ok = (data.count_ones() + (code as u32).count_ones()) & 1 == 0;
+
+    match (syn, parity_ok) {
+        (0, true) => SoftEccResult { status: 0, data },
+        // only the overall parity bit flipped; data intact
+        (0, false) => SoftEccResult { status: 1, data },
+        // an even number of flips keeps overall parity: beyond SECDED
+        (_, true) => SoftEccResult { status: -1, data },
+        (pos, false) => {
+            if pos > SECC_POSITIONS {
+                // impossible position: multi-bit corruption
+                SoftEccResult { status: -1, data }
+            } else if secc_is_parity_pos(pos) {
+                // a shadow parity bit flipped; data intact
+                SoftEccResult { status: 1, data }
+            } else {
+                // map the codeword position back to its data bit index
+                let mut bit = 0u32;
+                for p in 1..pos {
+                    if !secc_is_parity_pos(p) {
+                        bit += 1;
+                    }
+                }
+                SoftEccResult { status: 1, data: data ^ (1u64 << bit) }
+            }
+        }
+    }
+}
