+// ─── Memory sentinel (patch 0008) ────────────────────────────────────────────
+//
+// Lock-free fixed-window rate tracker for machine-check errors sourced
+// from the memory controller. Mirrored by the standalone crate
+// rust/rustlux_mm/src/mem_sentinel.rs (where the unit tests live).
+
+use core::sync::atomic::{AtomicU32, AtomicU64, Ordering};
+
+/// Sliding window for corrected-error accounting, in milliseconds.
+const MS_WINDOW_MS: u64 = 60_000;
+
+static MS_WINDOW_START: AtomicU64 = AtomicU64::new(0);
+static MS_WINDOW_COUNT: AtomicU32 = AtomicU32::new(0);
+
+/// Classify one memory error into an action for the C side.
+///
+/// Called from `rustlux_memsentinel_record()` in mm/rustlux_memsentinel.c.
+/// Safe from MCE context: atomics only, no locks, no allocation.
+///
+/// # Arguments
+/// * `now_ms` - boottime timestamp of the error, in milliseconds
+/// * `uncorrected` - 1 if the error was uncorrected (MCI_STATUS_UC)
+/// * `threshold` - corrected errors per window before warning
+///
+/// # Returns
+/// * 0 (`RUSTLUX_MS_ACTION_NONE`) - corrected error below threshold
+/// * 1 (`RUSTLUX_MS_ACTION_WARN`) - corrected-error storm: DRAM unstable
+/// * 2 (`RUSTLUX_MS_ACTION_OFFLINE`) - uncorrected: queue page to hwpoison
+#[no_mangle]
+pub extern "C" fn rustlux_memsentinel_on_error(now_ms: u64, uncorrected: u8, threshold: u32) -> i32 {
+    const ACTION_NONE: i32 = 0;
+    const ACTION_WARN: i32 = 1;
+    const ACTION_OFFLINE: i32 = 2;
+
+    if uncorrected != 0 {
+        return ACTION_OFFLINE;
+    }
+
+    let start = MS_WINDOW_START.load(Ordering::Relaxed);
+    if now_ms.wrapping_sub(start) > MS_WINDOW_MS {
+        // new window; only one CPU wins the reset
+        if MS_WINDOW_START
+            .compare_exchange(start, now_ms, Ordering::Relaxed, Ordering::Relaxed)
+            .is_ok()
+        {
+            MS_WINDOW_COUNT.store(0, Ordering::Relaxed);
+        }
+    }
+
+    let count = MS_WINDOW_COUNT.fetch_add(1, Ordering::Relaxed) + 1;
+    if count == threshold.max(1) {
+        ACTION_WARN
+    } else {
+        ACTION_NONE
+    }
+}
