+/// Check if a splice write to page cache should be permitted.
+///
+/// Called from `do_splice_from()` in fs/splice.c via the C inline wrapper.
+/// This is the Rust implementation backing `rustlux_check_splice_perm()`.
+///
+/// # Arguments
+/// * `i_mode` - inode mode bits (contains S_ISUID, S_ISGID)
+/// * `i_flags` - inode flags (contains FS_IMMUTABLE_FL)
+/// * `sb_readonly` - 1 if superblock is read-only, 0 otherwise
+///
+/// # Returns
+/// * 0 if write is allowed
+/// * negative errno if denied (-EPERM, -EROFS)
+#[no_mangle]
+pub extern "C" fn rustlux_check_splice_write(i_mode: u32, i_flags: u32, sb_readonly: u8) -> i32 {
+    const S_ISUID: u32 = 0o4000;
+    const S_ISGID: u32 = 0o2000;
+    const FS_IMMUTABLE_FL: u32 = 0x10;
+    const EPERM: i32 = -1;
+    const EROFS: i32 = -30;
+
+    // Block writes to SUID/SGID files (Dirty Pipe / Copy Fail / Dirty Frag)
+    if i_mode & (S_ISUID | S_ISGID) != 0 {
+        return EPERM;
+    }
+
+    // Block writes to immutable files
+    if i_flags & FS_IMMUTABLE_FL != 0 {
+        return EPERM;
+    }
+
+    // Block writes to read-only filesystems
+    if sb_readonly != 0 {
+        return EROFS;
+    }
+
+    0
+}
